# Скопируй в .env (gitignored) для локальной разработки.
VITE_API_URL=http://localhost:8000/api/
VITE_WS_URL=ws://localhost:8000/ws/updates

# Sitekey Cloudflare Turnstile — публичный (виден в DOM), не секрет.
# В прод-сборке передаётся как build-arg в Dockerfile.
VITE_TURNSTILE_SITEKEY=0x4AAAAAADRPdRR8t2m5Kd2h

# Dev login: упрощённый вход без капчи и OAuth (код всегда 000000).
# Оставь пустым или удали для прод-режима.
VITE_DEV_LOGIN=true
